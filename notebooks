        "# Create a copy for cleaning\n",
        "df_clean = df.copy()\n",
        "\n",
        "# 1. Clean Age column - remove invalid ages\n",
        "df_clean['Age'] = pd.to_numeric(df_clean['Age'], errors='coerce')\n",
        "df_clean = df_clean[(df_clean['Age'] >= 18) & (df_clean['Age'] <= 100)]\n",
        "\n",
        "# 2. Clean Gender column - standardize values\n",
        "df_clean['Gender'] = df_clean['Gender'].str.strip().str.title()\n",
        "gender_map = {\n",
        "    'Male': 'Male', 'M': 'Male', 'Man': 'Male', 'Cis Male': 'Male',\n",
        "    'Female': 'Female', 'F': 'Female', 'Woman': 'Female', 'Cis Female': 'Female',\n",
        "    'Trans Female': 'Female', 'Trans Male': 'Male'\n",
        "}\n",
        "df_clean['Gender'] = df_clean['Gender'].map(gender_map).fillna('Other')\n",
        "\n",
        "# 3. Clean treatment column\n",
        "df_clean['treatment'] = df_clean['treatment'].str.strip().map({'Yes': 'Yes', 'No': 'No'})\n",
        "\n",
        "# 4. Clean binary columns\n",
        "binary_cols = ['remote_work', 'tech_company', 'family_history', 'benefits']\n",
        "for col in binary_cols:\n",
        "    if col in df_clean.columns:\n",
        "        df_clean[col] = df_clean[col].str.strip().map({'Yes': 'Yes', 'No': 'No'})\n",
        "\n",
        "# 5. Create Age Groups for analysis\n",
        "bins = [0, 25, 35, 45, 55, 100]\n",
        "labels = ['18-25', '26-35', '36-45', '46-55', '55+']\n",
        "df_clean['age_group'] = pd.cut(df_clean['Age'], bins=bins, labels=labels)\n",
        "\n",
        "# 6. Create Company Size Groups\n",
        "df_clean['company_size_group'] = df_clean['no_employees'].map({\n",
        "    '1-5': 'Small', '6-25': 'Small', '26-100': 'Medium',\n",
        "    '100-500': 'Large', '500-1000': 'Large', 'More than 1000': 'Enterprise'\n",
        "}).fillna('Unknown')\n",
        "\n",
        "print(\"✅ Data cleaning complete!\")\n",
        "print(f\"Records after cleaning: {len(df_clean)}\")"
      ]
